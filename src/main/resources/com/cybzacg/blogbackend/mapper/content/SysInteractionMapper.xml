<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cybzacg.blogbackend.mapper.content.SysInteractionMapper">

    <resultMap id="BaseResultMap" type="com.cybzacg.blogbackend.domain.SysInteraction">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="userId" column="user_id" jdbcType="BIGINT"/>
        <result property="targetId" column="target_id" jdbcType="BIGINT"/>
        <result property="targetType" column="target_type" jdbcType="VARCHAR"/>
        <result property="actionType" column="action_type" jdbcType="VARCHAR"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,user_id,target_id,target_type,action_type,created_at
    </sql>

    <select id="existsUserAction" resultType="boolean">
        select count(1) &gt; 0
        from sys_interaction
        where user_id = #{userId}
          and target_id = #{targetId}
          and target_type = #{targetType}
          and action_type = #{actionType}
    </select>
</mapper>
