<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cybzacg.blogbackend.dto.mapper.auth.UserExperienceLogMapper">

    <resultMap id="BaseResultMap" type="com.cybzacg.blogbackend.dto.domain.auth.UserExperienceLog">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="source_type" property="sourceType" jdbcType="VARCHAR"/>
        <result column="source_biz_id" property="sourceBizId" jdbcType="VARCHAR"/>
        <result column="xp_value" property="xpValue" jdbcType="INTEGER"/>
        <result column="idempotent_key" property="idempotentKey" jdbcType="VARCHAR"/>
        <result column="log_date" property="logDate" jdbcType="DATE"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, source_type, source_biz_id, xp_value, idempotent_key, log_date, created_at
    </sql>

    <select id="sumXpByUserAndDate" resultType="java.lang.Integer">
        SELECT COALESCE(SUM(xp_value), 0)
        FROM user_experience_log
        WHERE user_id = #{userId}
          AND log_date = #{logDate}
    </select>

    <select id="sumXpByUserAndDateAndSource" resultType="java.lang.Integer">
        SELECT COALESCE(SUM(xp_value), 0)
        FROM user_experience_log
        WHERE user_id = #{userId}
          AND log_date = #{logDate}
          AND source_type = #{sourceType}
    </select>

</mapper>
